<div id="page-content">

  <h1 class="text-center mt-4">
    <%= @user.username %>'s profile
  </h1>

  <div class="text-center mt-4 mb-4">
    <%= gravatar_for @user, size: 200 %>
  </div>

  <h2 class="text-center">
    Articles
  </h2>

  <%= render "articles/article", articles: @articles %>

</div>